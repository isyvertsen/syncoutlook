# =============================================================================
# Outlook Calendar Sync - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# Outlook Calendar (Required)
# -----------------------------------------------------------------------------
# Get from: Outlook Web → Settings → Calendar → Shared calendars → Publish a calendar
OUTLOOK_ICS_URL=https://outlook.office365.com/owa/calendar/xxx/yyy/calendar.ics

# -----------------------------------------------------------------------------
# Google Calendar (Required)
# -----------------------------------------------------------------------------
# Create a service account in Google Cloud Console, download its JSON key as
# service_account.json in the project root, and share the target calendar with
# the service account's email ("Make changes to events").
# Calendar ID: the calendar's email address (a service account cannot use "primary")
GOOGLE_CALENDAR_ID=primary
#
# Coolify / container deploys: do NOT ship the key file. Instead paste the full
# contents of the service account JSON into this env var (takes precedence over
# the file). Set it as a secret in Coolify's environment variables.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# Local dev only: override the key file path (default: service_account.json)
# GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# -----------------------------------------------------------------------------
# AI Provider Configuration
# -----------------------------------------------------------------------------
# Choose your AI provider: "openai" (default), "azure", or "near_ai"
AI_PROVIDER=openai

# --- Option 1: OpenAI (Recommended) ---
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
# Optional: Custom endpoint (for OpenAI-compatible APIs)
# OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# --- Option 2: Azure OpenAI ---
# AZURE_OPENAI_API_KEY=your-azure-api-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
# Optional: Azure AD authentication (instead of API key)
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret

# --- Option 3: NEAR AI ---
# NEAR_AI_API_KEY=your-near-ai-api-key
# NEAR_AI_MODEL=openai/gpt-oss-120b
# NEAR_AI_API_URL=https://cloud-api.near.ai/v1/chat/completions

# -----------------------------------------------------------------------------
# Sync Settings
# -----------------------------------------------------------------------------
# Filter mode: "ai" for AI-based filtering, "non_recurring" for simple rule-based
FILTER_MODE=non_recurring

# Date range for sync (days)
SYNC_DAYS_AHEAD=30
SYNC_DAYS_BACK=7

# Minutes before event to set reminder (0 to disable)
REMINDER_MINUTES=10

# Sync interval in minutes (for scheduler)
SYNC_INTERVAL=15

# Dry run mode - set to true to test without making changes
DRY_RUN=false

# Log file path
LOG_FILE=sync.log
