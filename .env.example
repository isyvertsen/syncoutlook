# Outlook Calendar ICS feed URL
# Get from: Outlook Web → Settings → Calendar → Shared calendars → Publish a calendar
OUTLOOK_ICS_URL=https://outlook.office365.com/owa/calendar/xxx/yyy/calendar.ics

# Google Calendar
# Download credentials.json from Google Cloud Console and place in project root
GOOGLE_CALENDAR_ID=primary

# NEAR AI API
NEAR_AI_API_KEY=your-near-ai-api-key
NEAR_AI_MODEL=openai/gpt-oss-120b

# Sync settings
SYNC_DAYS_AHEAD=30
SYNC_DAYS_BACK=7
DRY_RUN=false
LOG_FILE=sync.log
